# Copy this file to .env and fill in your values. Never commit .env.

# --- Mock mode -------------------------------------------------------------
# "true"  -> agents run locally with deterministic logic (no Azure, no cost).
# "false" -> agents call real Azure AI Foundry models.
CERTFORGE_MOCK=true

# --- Azure AI Foundry ------------------------------------------------------
# Project endpoint (from the Foundry portal project overview screen)
PROJECT_ENDPOINT=https://<YourResourceName>.services.ai.azure.com/api/projects/<ProjectName>

# Model deployment name you created in Foundry
MODEL_DEPLOYMENT=gpt-4o

# Foundry IQ knowledge base id (created via portal or knowledge/setup_foundry_iq.py)
FOUNDRY_IQ_KB_ID=<your-knowledge-base-id>
