# Copy this file to certforge/.env and fill in your values. Never commit .env.

# --- Mock mode -------------------------------------------------------------
# "true"  -> agents run locally with deterministic logic (no LLM, no cost).
# "false" -> reasoning agents call a real LLM (GitHub Models by default).
CERTFORGE_MOCK=true

# --- LLM provider (used when CERTFORGE_MOCK=false) -------------------------
# Default provider is GitHub Models: free, OpenAI-compatible, no Azure quota.
LLM_PROVIDER=github
LLM_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# Your GitHub fine-grained token with the "Models" read permission.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=github_pat_your_token_here

# --- Azure AI Foundry (optional; only if LLM_PROVIDER=azure, or for Foundry IQ)
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
MODEL_DEPLOYMENT=gpt-4o-mini
FOUNDRY_IQ_KB_ID=<your-knowledge-base-id>
